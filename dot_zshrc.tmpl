# ~/.zshrc — interactive shell configuration

# --- History ---
HISTFILE="$HOME/.zsh_history"
HISTSIZE=50000
SAVEHIST=50000
setopt HIST_IGNORE_DUPS       # skip adjacent duplicate entries
setopt HIST_IGNORE_ALL_DUPS   # remove older duplicate on new entry
setopt HIST_IGNORE_SPACE      # don't record commands prefixed with a space
setopt HIST_REDUCE_BLANKS     # strip superfluous blanks
setopt HIST_VERIFY            # expand history before executing
setopt SHARE_HISTORY          # share history across all open sessions

# --- Shell options ---
setopt AUTO_CD                # type a dir name to cd into it
setopt CORRECT                # suggest corrections for mistyped commands
setopt NO_CASE_GLOB           # case-insensitive globbing
setopt GLOB_DOTS              # include dotfiles in glob patterns

# --- Completion ---
fpath+=~/.zfunc
autoload -Uz compinit && compinit
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Z}'  # case-insensitive completion

# --- Tools ---
eval "$(pyenv init -)"
eval "$(direnv hook zsh)"
eval "$(starship init zsh)"

export PATH="$HOME/.local/bin:$PATH"

{{ if eq .chezmoi.os "darwin" -}}
# --- macOS ---
export CONTAINERS_MACHINE_PROVIDER=applehv
{{ end -}}

# --- Aliases ---
alias ai="claude --permission-mode bypassPermissions"
{{ if eq .chezmoi.os "darwin" -}}
alias devclean='podman ps -q | xargs -r podman stop; podman system prune -af --volumes'
{{ end -}}

# --- Machine-local overrides (not committed) ---
[[ -f ~/.zshrc.local ]] && source ~/.zshrc.local
