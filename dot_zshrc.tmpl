# =============================================================================
# Universal zsh configuration
# Platform-specific additions live at the bottom, clearly separated.
# Machine-local overrides go in ~/.zshrc.local (never committed).
# =============================================================================

# --- History ---
HISTFILE="$HOME/.zsh_history"
HISTSIZE=50000
SAVEHIST=50000
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_IGNORE_SPACE
setopt HIST_REDUCE_BLANKS
setopt HIST_VERIFY
setopt SHARE_HISTORY

# --- Shell behaviour ---
setopt AUTO_CD
setopt CORRECT
setopt NO_CASE_GLOB
setopt GLOB_DOTS

# --- Completion ---
fpath+=~/.zfunc
autoload -Uz compinit && compinit
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Z}'

# --- PATH ---
export PATH="$HOME/.local/bin:$PATH"

# --- Core tools (guarded — shell stays functional if a tool isn't installed) ---
command -v pyenv   >/dev/null && eval "$(pyenv init -)"
command -v direnv  >/dev/null && eval "$(direnv hook zsh)"
command -v starship >/dev/null && eval "$(starship init zsh)"

# --- Aliases ---
alias ai="claude --permission-mode bypassPermissions"

# =============================================================================
# macOS
# =============================================================================
{{ if eq .chezmoi.os "darwin" -}}
export CONTAINERS_MACHINE_PROVIDER=applehv
alias devclean='podman ps -q | xargs -r podman stop; podman system prune -af --volumes'
{{- end }}

# =============================================================================
# Machine-local overrides — not committed, for per-machine aliases/paths/env
# =============================================================================
[[ -f ~/.zshrc.local ]] && source ~/.zshrc.local
