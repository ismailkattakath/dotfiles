# Login shell: PATH setup and secrets.
# Keep this file minimal — interactive config belongs in ~/.zshrc.

# pyenv root on PATH so `pyenv` is available before zshrc runs
export PYENV_ROOT="$HOME/.pyenv"
[[ -d $PYENV_ROOT/bin ]] && export PATH="$PYENV_ROOT/bin:$PATH"

# Secrets — chmod 600, never committed
[[ -f ~/.secrets ]] && set -a && source ~/.secrets && set +a

# HuggingFace — mirrors huggingface-cli auth state
[[ -f ~/.cache/huggingface/token ]] && \
  export HF_TOKEN=$(<~/.cache/huggingface/token) && \
  export HUGGINGFACE_TOKEN="$HF_TOKEN"

# =============================================================================
# macOS
# =============================================================================
{{ if eq .chezmoi.os "darwin" -}}
[[ -x /opt/homebrew/bin/brew ]] && eval "$(/opt/homebrew/bin/brew shellenv zsh)"
{{- end }}
