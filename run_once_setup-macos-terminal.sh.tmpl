#!/usr/bin/env bash
# macOS only — creates / updates the "Ubuntu" profile in Terminal.app.
# Runs once on first apply, or whenever this file changes.
{{ if ne .chezmoi.os "darwin" }}exit 0{{ end }}

set -euo pipefail

echo "Setting up Ubuntu Terminal.app profile..."

osascript <<'APPLESCRIPT'
tell application "Terminal"

    if not (exists settings set "Ubuntu") then
        make new settings set with properties {name:"Ubuntu"}
    end if

    set s to settings set "Ubuntu"

    -- Background: #300A24 (Ubuntu maroon-purple)  values are 0-65535
    set background color of s   to {12337, 2571, 9247}

    -- Foreground: #FFFFFF
    set normal text color of s  to {65535, 65535, 65535}
    set bold text color of s    to {65535, 65535, 65535}

    -- Cursor: #8AE234 (bright green)
    set cursor color of s       to {35466, 58025, 13364}

    -- Font: Ubuntu Mono 16pt
    set font name of s to "UbuntuMono Nerd Font"
    set font size of s to 16

end tell
APPLESCRIPT

echo ""
echo "Ubuntu profile created in Terminal.app."
echo ""
echo "One-time manual step: set the 16 ANSI colours."
echo "Terminal.app > Settings > Profiles > Ubuntu > Colours"
echo ""
echo "Normal colours          Bright colours"
echo "Black:   #2E3436        Black:   #555753"
echo "Red:     #CC0000        Red:     #EF2929"
echo "Green:   #4E9A06        Green:   #8AE234"
echo "Yellow:  #C4A000        Yellow:  #FCE94F"
echo "Blue:    #3465A4        Blue:    #729FCF"
echo "Magenta: #75507B        Magenta: #AD7FA8"
echo "Cyan:    #06989A        Cyan:    #34E2E2"
echo "White:   #D3D7CF        White:   #EEEEEC"
